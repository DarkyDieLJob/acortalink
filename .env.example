# Django
SECRET_KEY=change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# Database (SQLite for dev, PostgreSQL for prod)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=acortalink
# DB_USER=acortalink
# DB_PASSWORD=secret
# DB_HOST=127.0.0.1
# DB_PORT=5432

# Cache (use locmem for dev without Redis)
CACHE_BACKEND=locmem
# REDIS_URL=redis://127.0.0.1:6379/0

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@localhost

# Payment
PAYMENT_PROVIDER=mercadopago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_CURRENCY=ARS

# Pricing por plan (ARS/mes) — 30% por debajo de competidores
PLAN_PRICE_STARTER=4900
PLAN_PRICE_PRO=9800
PLAN_PRICE_BUSINESS=28000

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Encryption
FIELD_ENCRYPTION_KEY=

# Site
SITE_URL=https://acortalink.com.ar
CNAME_TARGET=app.acortalink.com.ar
